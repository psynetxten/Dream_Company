{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Stack (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 3000
    },
    {
      "name": "dev-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "-p", "3010"],
      "cwd": "./frontend",
      "port": 3010
    },
    {
      "name": "Backend (FastAPI dev)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "./backend",
      "port": 8000
    },
    {
      "name": "User Portal (3000)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "frontend-user", "backend", "postgres", "chromadb"],
      "port": 3000
    },
    {
      "name": "Writer Portal (3001)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "frontend-writer", "backend", "postgres", "chromadb"],
      "port": 3001
    },
    {
      "name": "Sponsor Portal (3002)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "frontend-sponsor", "backend", "postgres", "chromadb"],
      "port": 3002
    },
    {
      "name": "Backend API (3003)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "backend", "postgres", "chromadb"],
      "port": 3003
    }
  ]
}
