# ============================================
# 꿈신문사 환경변수 설정
# cp .env.example .env 후 값을 채워넣으세요
# ============================================

# ============================
# 필수 - AI API
# ============================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================
# 필수 - 보안
# ============================
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================
# 데이터베이스 (로컬 PostgreSQL)
# ============================
POSTGRES_USER=dream
POSTGRES_PASSWORD=dream_secret_change_me
POSTGRES_DB=dream_newspaper
DATABASE_URL=postgresql+asyncpg://dream:dream_secret_change_me@localhost:5432/dream_newspaper

# ============================
# Supabase DB 연결 (test_db_conn.py 전용)
# Supabase → Settings → Database 에서 확인
# ============================
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_REGION=ap-northeast-2

# ============================
# ChromaDB
# ============================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_AUTH_TOKEN=dream_chroma_token_change_me

# ============================
# 앱 설정
# ============================
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ============================
# 소셜 로그인 (OAuth)
# ============================
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================
# AI 모델 설정
# ============================
ORCHESTRATOR_MODEL=claude-sonnet-4-5-20250929
WRITER_MODEL=claude-haiku-4-5-20251001
SPONSOR_MODEL=claude-haiku-4-5-20251001
MAX_CONCURRENT_GENERATIONS=5

# ============================
# 스케줄러 설정
# ============================
PUBLISH_HOUR=8
PUBLISH_MINUTE=0
PUBLISH_TIMEZONE=Asia/Seoul

# ============================
# 이메일 (Phase 2 - 선택)
# ============================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=app-specific-password

# ============================
# 결제 (Phase 2 - 선택)
# ============================
# PORTONE_API_KEY=
# PORTONE_API_SECRET=
# TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
